# Doxyfile for MyTinySTL

# 项目信息
PROJECT_NAME           = "MyTinySTL"
PROJECT_NUMBER         = "@PROJECT_VERSION@"
PROJECT_BRIEF          = "A lightweight STL implementation based on C++11"

# 输入和输出
INPUT                  = @CMAKE_CURRENT_SOURCE_DIR@/MyTinySTL/include
OUTPUT_DIRECTORY       = @CMAKE_CURRENT_BINARY_DIR@/docs
RECURSIVE              = YES
FILE_PATTERNS          = *.h *.hpp *.cpp

# 生成选项
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_XML           = NO

# HTML选项
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
HTML_COLORSTYLE_HUE    = 220
HTML_COLORSTYLE_SAT    = 100
HTML_COLORSTYLE_GAMMA  = 80

# 提取选项
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES

# 源代码浏览
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = YES

# 图形生成
HAVE_DOT               = NO
CLASS_DIAGRAMS         = YES
COLLABORATION_GRAPH    = YES
GROUP_GRAPHS           = YES
UML_LOOK               = NO
TEMPLATE_RELATIONS     = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO

# 其他选项
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO

# 预处理器
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO
SEARCH_INCLUDES        = YES
INCLUDE_PATH           = @CMAKE_CURRENT_SOURCE_DIR@/MyTinySTL/include

# 搜索引擎
SEARCHENGINE           = YES
